# Banco de dados
DATABASE_URL=sqlite+aiosqlite:///./app.db

# JWT — troque a chave secreta em producao
JWT_SECRET_KEY=mude-esta-chave-secreta-em-producao
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# IA — escolha o provedor: ollama | xai | groq | openai
AI_PROVIDER=ollama
AI_MODEL=qwen2.5:1.5b

# Chaves de API (preencha apenas o provedor escolhido)
XAI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
